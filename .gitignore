__pycache__/
*.py[cod]
.venv/
venv/
.env

# All datasets are gitignored — raw, processed, and external (e.g. ISIC 2019,
# ~3.6 GB) live under data/ locally and must never enter the repo. This catch-all
# replaces the former explicit data/raw/ + data/processed/ lines.
# NOTE: use data/* (not data/) so the .gitkeep negation below works — a bare
# "data/" directory exclusion would make the negation a no-op.
data/*
!data/.gitkeep
runs/
/models/

.pytest_cache/
.mypy_cache/
.ruff_cache/

*.pt
*.pth
*.onnx
*.log

mobile_app/.dart_tool/
mobile_app/.flutter-plugins
mobile_app/.flutter-plugins-dependencies
mobile_app/.packages
mobile_app/build/

.claude/ 
 
 